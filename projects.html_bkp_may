<!DOCTYPE html>
<html>
<head>
    <title>Certifications | Nishi Sheeba</title>
    <link rel="stylesheet" href="css/styles.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <script>
    // SHA256 hash for "Nishi31"
    const correctHash = "6f4b6612126f0b9f5d0d7f2f4bbfdfb6dcbf07c6c9bbdb0b3c3d1d0a1b6e5c3d";

    const userInput = prompt("Enter password to access projects:");

    // Handle cancel or empty input
    if(!userInput){
        alert("Access cancelled!");
        window.location.href = "index.html";
    } else {
        const userHash = CryptoJS.SHA256(userInput.trim()).toString();

        if(userHash !== correctHash){
            alert("Incorrect password!");
            window.location.href = "index.html";
        }
    }
    </script>
</head>
