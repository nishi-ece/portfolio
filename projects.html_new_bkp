    <script>
    // SHA256 hash of your password (e.g., "Nishi123")
    const correctHash = "a4bfbf4697e8e72d0d51f1d2f4c8120c29f2bde7e1d4b657ab3c2a6f5de0c0c0";

    const userInput = prompt("Enter password to access projects:");
    const userHash = CryptoJS.SHA256(userInput).toString();

    if(userHash !== correctHash){
        alert("Incorrect password!");
        window.location.href = "index.html";
    }
    </script>
</head>
